# 寒江（HanJiang）环境变量配置
# 复制本文件为 .env 并填写实际值

# 运行环境：development / testing / production
APP_ENV=development

# 服务配置
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# 认证配置
AUTH_SECRET_KEY=change-me-in-production
AUTH_ALGORITHM=HS256

# 数据库连接（MySQL）
# 格式：mysql://用户名:密码@主机:端口/数据库名
# 或使用 pymysql 驱动：mysql+pymysql://用户名:密码@主机:端口/数据库名
DATABASE_URL=mysql://root:123456@localhost:3306/hanjiang

# 数据库连接池大小
DATABASE_POOL_SIZE=5

# Redis 连接（可选）
REDIS_URL=
